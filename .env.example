# webhook-receiver-tool environment variables
# Copy this file to .env and adjust values as needed.
# All variables are optional — defaults are shown below.

# ── Base URL ─────────────────────────────────────────────────────────────────
# Base URL path for the application (e.g., /webhook-tool). Leave empty if at root.
# Useful when running behind a reverse proxy with a path prefix.
BASE_URL=

# ── Rate limiting ────────────────────────────────────────────────────────────
# Maximum number of requests per IP address per RATE_LIMIT_WINDOW.
RATE_LIMIT_MAX=100

# Time window for rate limiting. Accepts: "30 seconds", "5 minutes", "1 hour", etc.
RATE_LIMIT_WINDOW=1 minute

# ── Connection limits ────────────────────────────────────────────────────────
# Maximum concurrent SSE viewer connections allowed per webhook path.
# Requests beyond this cap receive HTTP 503.
MAX_VIEWERS_PER_PATH=50

# ── Resource limits ───────────────────────────────────────────────────────────
# Idle timeout in milliseconds. Viewers inactive for this duration are removed.
# Default: 18000000 (5 hours).
IDLE_TIMEOUT_MS=18000000

# Maximum messages per viewer queue. Oldest messages are dropped when full.
# Default: 500.
QUEUE_SIZE_LIMIT=500

# ── Request body ─────────────────────────────────────────────────────────────
# Maximum incoming body size in bytes. Default 65536 (64 KB).
# Increase only if you expect large webhook payloads (e.g. GitHub push events).
BODY_LIMIT_BYTES=65536
